{
  "name": "wpmcp/wpmcp",
  "description": "AI builds and edits your WordPress site, and physically can't wreck it.",
  "license": "GPL-2.0-or-later",
  "require": { "php": ">=8.1",
    "freemius/wordpress-sdk": "^2.13" },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "yoast/phpunit-polyfills": "^2.0",
    "wp-phpunit/wp-phpunit": "^6.9",
    "squizlabs/php_codesniffer": "^3.9"
  },
  "autoload": { "psr-4": { "WPMCP\\": "src/" } },
  "autoload-dev": { "psr-4": { "WPMCP\\Tests\\Free\\": "tests/free/", "WPMCP\\Tests\\Pro\\": "tests/pro/" } },
  "scripts": {
    "test": "phpunit",
    "test:free": "phpunit --testsuite free",
    "test:pro": "phpunit --testsuite pro",
    "test:coverage": "phpunit --coverage-clover coverage/clover.xml --coverage-text",
    "manifest:regenerate": "WPMCP_REGENERATE_MANIFEST=1 phpunit --filter AbilityManifestTest",
    "lint": "phpcs -q"
  },
  "config": {
    "allow-plugins": { "*": true },
    "platform": { "php": "8.1.0" }
  }
}
