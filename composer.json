{
  "name": "wpmcp/wpmcp",
  "description": "AI builds and edits your WordPress site — and physically can't wreck it.",
  "license": "GPL-2.0-or-later",
  "require": { "php": ">=8.1" },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "yoast/phpunit-polyfills": "^2.0",
    "wp-phpunit/wp-phpunit": "^6.9",
    "squizlabs/php_codesniffer": "^3.9"
  },
  "autoload": { "psr-4": { "WPMCP\\": "src/" } },
  "autoload-dev": { "psr-4": { "WPMCP\\Tests\\": "tests/" } },
  "scripts": {
    "test": "phpunit",
    "lint": "phpcs -q"
  },
  "config": {
    "allow-plugins": { "*": true },
    "platform": { "php": "8.1.0" }
  }
}
